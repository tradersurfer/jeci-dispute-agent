# ══════════════════════════════════════════════════════
# CREDORA AI — Environment Variables
# Copy to .env.local and fill in real values
# ══════════════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic / Claude AI
ANTHROPIC_API_KEY=

# Stripe Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (create in Stripe dashboard → Products)
NEXT_PUBLIC_STRIPE_PRICE_SCAN=price_credora_scan
NEXT_PUBLIC_STRIPE_PRICE_SWEEP=price_credora_sweep
NEXT_PUBLIC_STRIPE_PRICE_REPAIR=price_credora_repair

# App
NEXT_PUBLIC_BASE_URL=https://your-netlify-site.netlify.app
AGENT_WEBHOOK_SECRET=

# CRC Integration (optional)
CRC_API_KEY=
CRC_SECRET_KEY=
CRC_API_URL=https://api.creditrepaircloud.com/v2

# Slack Notifications (optional)
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_CHANNEL_ID=

# Server (legacy Express)
PORT=3000
NODE_ENV=production
POLL_INTERVAL_MINUTES=5
