# ============================================================
# JECI AI Dispute Agent — Environment Variables
# 700 Credit Club Experts | JECI Group
# Copy to .env and fill in your values.
# ============================================================

# ── Credit Repair Cloud (CRC) ─────────────────────────────────
# Get these from CRC → Settings → API
CRC_API_KEY=your_crc_api_key
CRC_SECRET_KEY=your_crc_secret_key

# Set to true once you upgrade to CRC Grow/Scale plan.
# While on free/trial plan, leave as false.
# Credit Hero Score API will still work regardless of this setting.
CRC_API_ENABLED=false

# ── Claude AI ─────────────────────────────────────────────────
# Generates FCRA/FDCPA-compliant dispute letters
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Slack Notifications ───────────────────────────────────────
# Real-time alerts to #credit-club-operations
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_CHANNEL_ID=#credit-club-operations

# ── SendGrid (Client Emails) ──────────────────────────────────
# Sends clients copies of all dispute letters and communications.
# Use a verified sender domain in SendGrid.
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=disputes@700creditclub.com
SENDGRID_FROM_NAME=700 Credit Club Experts | JECI Group

# ── Credit Hero Score API ─────────────────────────────────────
# Primary report data source. Client pulls report in Credit Hero
# Score portal → it syncs to this API.
# Contact Credit Hero Score for API access credentials.
CREDIT_HERO_API_KEY=your_credit_hero_api_key
CREDIT_HERO_API_URL=https://api.creditheroscore.com/v1

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# How often to poll CRC for client stage changes (minutes).
# 60 minutes is recommended for production.
# Lower during testing (e.g. 5) to trigger faster.
POLL_INTERVAL_MINUTES=60

# ── CRC Webhooks ──────────────────────────────────────────────
# Configure these URLs in CRC → Settings → Webhooks.
# Replace <your-railway-domain> with your Railway app URL.
#
# POST <your-railway-domain>/webhook/new-client        → client enrolls
# POST <your-railway-domain>/webhook/report-uploaded   → credit report ready
# POST <your-railway-domain>/webhook/bureau-response   → bureau responds
# POST <your-railway-domain>/webhook/deletion-confirmed → item removed
