# ================================================================
# JECI CREDIT — Environment Variables
# Copy to .env.local and fill in real values
# ================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — Claude AI Engine
ANTHROPIC_API_KEY=

# Stripe — Payment Processing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (create in Stripe Dashboard → Products)
NEXT_PUBLIC_STRIPE_PRICE_SCAN=
NEXT_PUBLIC_STRIPE_PRICE_SWEEP=
NEXT_PUBLIC_STRIPE_PRICE_REPAIR=
NEXT_PUBLIC_STRIPE_PRICE_BOOST=

# App
NEXT_PUBLIC_BASE_URL=https://your-site.netlify.app
AGENT_WEBHOOK_SECRET=

# CRC Integration (optional)
CRC_API_KEY=
CRC_SECRET_KEY=
CRC_API_URL=https://api.creditrepaircloud.com/v2

# Slack Notifications (optional)
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_CHANNEL_ID=

# Server (legacy Express)
PORT=3000
NODE_ENV=production
POLL_INTERVAL_MINUTES=5
